{
  "name": "nodefactory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Satisfactory 1.0 factory planner — calculateur d'usines open source, 100% client.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
